# Copy to register-api/.env (chmod 600). Never commit .env.

# Graph API — dedicated service user with permission to POST /graph/v1.0/users
GRAPH_SERVICE_USER=register-service
GRAPH_SERVICE_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Internal OpenCloud Graph endpoint (Docker network)
GRAPH_BASE_URL=http://opencloud:9200

# CORS — must match public origin
ALLOWED_ORIGIN=https://cloud.km0digital.com

# Align with OpenCloud compose (OC_PASSWORD_POLICY_MIN_SPECIAL_CHARACTERS)
MIN_PASSWORD_LENGTH=8
MIN_SPECIAL_CHARACTERS=1
