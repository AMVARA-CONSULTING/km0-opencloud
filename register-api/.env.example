# Copy to register-api/.env (chmod 600). Never commit .env.

# Graph API — user with permission to POST /graph/v1.0/users (admin or delegated role).
# Auth uses an app token (required in production; password Basic auth only works when
# PROXY_ENABLE_BASIC_AUTH=true, which is disabled by default).
GRAPH_SERVICE_USER=admin
GRAPH_SERVICE_APP_TOKEN=RUN_scripts_setup-register-api-graph-token.sh
# Set automatically by setup-register-api-graph-token.sh (ISO8601 UTC):
# GRAPH_SERVICE_APP_TOKEN_EXPIRES_AT=2026-10-04T12:00:00Z

# Legacy (dev/test only — ignored when GRAPH_SERVICE_APP_TOKEN is set):
# GRAPH_SERVICE_PASSWORD=

# Internal OpenCloud Graph endpoint (Docker network)
GRAPH_BASE_URL=http://opencloud:9200

# CORS — must match public origin
ALLOWED_ORIGIN=https://cloud.km0digital.com

# Align with OpenCloud compose (OC_PASSWORD_POLICY_MIN_SPECIAL_CHARACTERS)
MIN_PASSWORD_LENGTH=8
MIN_SPECIAL_CHARACTERS=1
