# Dex OIDC broker — plantilla (cp .env.example .env && chmod 600 .env)
DEX_DOMAIN=cloud.example.com
DEX_ISSUER=https://cloud.example.com/dex

# Google Cloud Console → OAuth client (o /opt/google-client-secret.json en el servidor)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Apple Sign In (opcional; ver README.md y setup-apple.sh)
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY_B64=

OPENCLOUD_WEB_CLIENT_ID=opencloud-web

# openssl rand -hex 32 (solo si aplica)
DEX_STATIC_CLIENT_SECRET=
