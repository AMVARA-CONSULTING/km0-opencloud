# OpenCloud collaboration (WOPI) service — TLS termination + reverse proxy to 127.0.0.1:9300
# Production: https://wopi.km0digital.com

server {
    listen 80;
    listen [::]:80;
    server_name wopi.km0digital.com;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name wopi.km0digital.com;

    ssl_certificate     /etc/letsencrypt/live/wopi.km0digital.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/wopi.km0digital.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    include /etc/nginx/snippets/collabora-proxy.conf;

    location / {
        proxy_pass http://127.0.0.1:9300;
    }

    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;
}
