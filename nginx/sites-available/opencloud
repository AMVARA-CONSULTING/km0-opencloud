# OpenCloud — Dex OIDC (/dex) + OpenCloud (127.0.0.1:9200)
# Temporary Google OAuth test: use https://cloud.km0.amvara.de (Console redirect URIs)
# Production hostname: cloud.km0digital.com (restore OC_DOMAIN / DEX_ISSUER when Console is updated)

server {
    listen 80;
    listen [::]:80;
    server_name cloud.km0digital.com cloud.km0.amvara.de;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
        allow all;
        try_files $uri =404;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name cloud.km0digital.com;

    ssl_certificate     /etc/letsencrypt/live/cloud.km0digital.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/cloud.km0digital.com/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    client_max_body_size 10G;

    proxy_buffering off;
    proxy_request_buffering off;

    proxy_read_timeout 3600s;
    proxy_send_timeout 3600s;
    keepalive_requests 100000;
    keepalive_timeout 5m;

    proxy_next_upstream off;

    include /etc/nginx/snippets/opencloud-locations.conf;
}

