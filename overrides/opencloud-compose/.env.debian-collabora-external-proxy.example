## Debian — OpenCloud + Collabora Online (CODE) + WOPI behind Nginx + Let's Encrypt
## On the server:
##   cp overrides/opencloud-compose/.env.debian-collabora-external-proxy.example opencloud-compose/.env
##   chmod 600 opencloud-compose/.env && nano opencloud-compose/.env
##
## Prerequisites: DNS A/AAAA for cloud, collabora, and wopi hostnames → same server IP.
## Rollback to core-only: use .env.debian-core-external-proxy.example instead.

COMPOSE_FILE=docker-compose.yml:weboffice/collabora.yml:external-proxy/opencloud.yml:external-proxy/collabora.yml
COMPOSE_PROJECT_NAME=opencloud

INSECURE=false
OC_DOMAIN=cloud.km0digital.com

INITIAL_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

OC_DOCKER_IMAGE=opencloudeu/opencloud-rolling
OC_DOCKER_TAG=7.0.0

LOG_DRIVER=json-file
LOG_LEVEL=info
DEMO_USERS=false

OC_URL=https://cloud.km0digital.com

# Collabora Online CODE (browser document editing)
COLLABORA_DOMAIN=collabora.km0digital.com
WOPISERVER_DOMAIN=wopi.km0digital.com

COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=CHANGE_ME_COLLABORA_ADMIN_PASSWORD

# Nginx terminates TLS; Collabora listens HTTP on loopback :9980
COLLABORA_SSL_ENABLE=false
COLLABORA_SSL_VERIFICATION=false
# COLLABORA_HOME_MODE=false

# Dex OIDC (after deploying dex/ and nginx)
OC_OIDC_ISSUER=https://cloud.km0digital.com/dex
WEB_OIDC_CLIENT_ID=opencloud-web
PROXY_OIDC_REWRITE_WELLKNOWN=true
PROXY_OIDC_ACCESS_TOKEN_VERIFY_METHOD=jwt
PROXY_AUTOPROVISION_ACCOUNTS=true
GRAPH_USERNAME_MATCH=none
PROXY_USER_OIDC_CLAIM=email
PROXY_AUTOPROVISION_CLAIM_USERNAME=email
PROXY_USER_CS3_CLAIM=username
PROXY_ROLE_ASSIGNMENT_DRIVER=default
GRAPH_ASSIGN_DEFAULT_USER_ROLE=true
